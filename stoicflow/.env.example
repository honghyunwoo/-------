# StoicFlow Configuration
# Copy this file to .env and fill in your values

# ===============================================
# LLM Provider (required for script generation)
# ===============================================
# Options: claude, gemini, ollama
STOICFLOW_LLM_PROVIDER=claude

# Anthropic Claude API Key
STOICFLOW_ANTHROPIC_API_KEY=sk-ant-xxx

# Google Gemini API Key (alternative to Claude)
# STOICFLOW_GEMINI_API_KEY=xxx

# Ollama Host (for local LLM - free alternative)
# STOICFLOW_OLLAMA_HOST=http://localhost:11434
# STOICFLOW_OLLAMA_MODEL=llama3.2

# ===============================================
# TTS Provider (optional - default: skip for manual recording)
# ===============================================
# Options: edge (free), elevenlabs (premium), skip
STOICFLOW_TTS_PROVIDER=skip

# ElevenLabs API Key (for premium TTS)
# STOICFLOW_ELEVENLABS_API_KEY=xxx

# Microsoft Edge TTS Voice ID
STOICFLOW_EDGE_VOICE=ko-KR-SunHiNeural

# ===============================================
# Video Settings
# ===============================================
STOICFLOW_VIDEO_WIDTH=1080
STOICFLOW_VIDEO_HEIGHT=1920
STOICFLOW_VIDEO_FPS=30
STOICFLOW_BACKGROUND_MUSIC_VOLUME=0.1

# ===============================================
# Subtitle Settings
# ===============================================
STOICFLOW_SUBTITLE_FONT=NanumGothic
STOICFLOW_SUBTITLE_FONT_SIZE=60
STOICFLOW_SUBTITLE_COLOR=white
STOICFLOW_SUBTITLE_STROKE_COLOR=black
STOICFLOW_SUBTITLE_STROKE_WIDTH=3

# ===============================================
# YouTube Upload Settings
# ===============================================
# Path to OAuth client secrets JSON file
STOICFLOW_YOUTUBE_CLIENT_SECRETS=client_secret.json

# Default privacy: public, private, unlisted
STOICFLOW_YOUTUBE_DEFAULT_PRIVACY=private

# Category ID (22 = People & Blogs)
STOICFLOW_YOUTUBE_DEFAULT_CATEGORY=22

# ===============================================
# Media (optional)
# ===============================================
# Pexels API Key (for stock video backgrounds)
# STOICFLOW_PEXELS_API_KEY=xxx

# ===============================================
# Paths
# ===============================================
STOICFLOW_DATA_DIR=data
