# 🦉 올빼미 AI 영상 스튜디오 - 환경 변수 설정 예제
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요
# 명령어: cp .env.example .env

# ============================================
# 🗄️ 데이터베이스 설정
# ============================================

# 개발 환경에서는 SQLite 사용 (true), 프로덕션에서는 PostgreSQL 사용 (false)
USE_SQLITE=true

# PostgreSQL 데이터베이스 URL (USE_SQLITE=false일 때 필수)
# 형식: postgresql://username:password@host:port/database
# 예시: DATABASE_URL=postgresql://owl_user:your_secure_password@localhost:5432/owl_studio
DATABASE_URL=

# ============================================
# 🔐 인증 및 보안
# ============================================

# JWT 시크릿 키 (랜덤한 긴 문자열 사용 권장)
# 생성 방법: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-this

# JWT 토큰 만료 시간 (분)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# 🤖 OpenAI API 설정
# ============================================

# OpenAI API 키
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI 모델명
OPENAI_MODEL_NAME=gpt-4o-mini

# OpenAI Base URL (선택)
OPENAI_API_BASE=

# ============================================
# ☁️ Azure OpenAI 설정 (선택)
# ============================================

# Azure OpenAI API 키
AZURE_OPENAI_API_KEY=

# Azure OpenAI 엔드포인트
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI 배포명
AZURE_OPENAI_DEPLOYMENT_NAME=

# Azure API 버전
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============================================
# 🎤 음성 합성 (TTS) 설정
# ============================================

# Azure Speech API 키 (선택)
AZURE_SPEECH_KEY=

# Azure Speech 리전
AZURE_SPEECH_REGION=koreacentral

# Edge TTS 사용 (무료, 별도 키 불필요)
USE_EDGE_TTS=true

# ============================================
# 📺 YouTube API 설정 (선택)
# ============================================

# YouTube Data API v3 키
# 발급: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# ============================================
# 🎨 이미지 생성 AI (선택)
# ============================================

# DALL-E API (OpenAI 키 사용)
# 또는 Pollinations AI (무료, 키 불필요)

# ============================================
# 💳 결제 시스템 (Week 2에 추가 예정)
# ============================================

# 토스페이먼츠 시크릿 키
TOSS_PAYMENTS_SECRET_KEY=

# 토스페이먼츠 클라이언트 키
TOSS_PAYMENTS_CLIENT_KEY=

# ============================================
# 📧 이메일 설정
# ============================================

# SMTP 서버 설정
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# 발신자 이메일
EMAIL_FROM=noreply@owl-studio.com

# ============================================
# 🔍 모니터링 (Week 4에 추가 예정)
# ============================================

# Sentry DSN (에러 추적)
SENTRY_DSN=

# ============================================
# 🚀 애플리케이션 설정
# ============================================

# 환경 (development, staging, production)
ENVIRONMENT=development

# 디버그 모드
DEBUG=true

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================
# 🌐 서버 설정
# ============================================

# 서버 호스트
HOST=0.0.0.0

# 서버 포트
PORT=8080

# 허용 CORS 도메인 (쉼표로 구분)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# ============================================
# 📝 참고사항
# ============================================

# 1. 이 파일은 Git에 커밋하지 마세요 (.gitignore에 포함됨)
# 2. 프로덕션 환경에서는 반드시 강력한 비밀번호 사용
# 3. JWT_SECRET_KEY는 절대 노출되지 않도록 주의
# 4. 각 환경(dev/staging/prod)마다 다른 .env 파일 사용 권장
# 5. 민감 정보는 AWS Secrets Manager 등 사용 권장 (프로덕션)
