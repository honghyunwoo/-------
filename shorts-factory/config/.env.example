# Shorts Factory - Environment Variables
# Copy this file to .env and fill in your API keys

# Claude API (Required)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-claude-api-key

# TYPECAST API (Required for Korean TTS)
# Get your key at: https://typecast.ai/
TYPECAST_API_KEY=your-typecast-api-key

# ElevenLabs API (Required for English TTS)
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Optional - YouTube API (for future auto-upload feature)
# YOUTUBE_API_KEY=your-youtube-api-key
